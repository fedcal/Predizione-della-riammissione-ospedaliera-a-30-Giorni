# Gemfile per la documentazione (Jekyll + Just the Docs).
# Usato dal workflow GitHub Actions `.github/workflows/jekyll.yml`
# per buildare il sito statico in produzione, e localmente per il preview:
#
#   gem install bundler
#   bundle install
#   bundle exec jekyll serve --livereload
#   # apri http://127.0.0.1:4000/hospital-readmission-30d/

source "https://rubygems.org"

# Jekyll 4.x è richiesto da just-the-docs >= 0.10
gem "jekyll", "~> 4.3"

# Tema documentazione (gem locale — più affidabile del remote_theme)
gem "just-the-docs", "~> 0.10.1"

group :jekyll_plugins do
  gem "jekyll-seo-tag", "~> 2.8"
  gem "jekyll-sitemap", "~> 1.4"
  gem "jekyll-include-cache", "~> 0.2"
end

# Webrick è richiesto da Ruby >= 3.0 per `jekyll serve`
gem "webrick", "~> 1.8"

# Windows / JRuby (innocuo su Linux/macOS)
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]
