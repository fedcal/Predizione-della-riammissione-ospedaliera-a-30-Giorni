# --- Dati grezzi e processati ---
# Il dataset UCI 296 (Diabetes 130-US Hospitals) NON è committato:
# va scaricato manualmente in data/raw/ (diabetic_data.csv + IDS_mapping.csv).
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/external/*
!data/external/.gitkeep

# --- Modelli serializzati ---
# Rigenerati da `readmit-train`. ~10-50 MB ciascuno → fuori dal repo.
reports/models/*
!reports/models/.gitkeep

# --- Output di training (riproducibili) ---
reports/cv_summary.csv
reports/holdout_metrics.json
reports/fairness_report.csv
reports/fairness_report.json

